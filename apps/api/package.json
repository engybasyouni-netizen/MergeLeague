{
  "name": "@mergeleague/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "rewards:distribute": "node dist/scripts/distribute-season-rewards.js",
    "db:generate": "npm run generate --workspace=@mergeleague/database",
    "db:migrate:deploy": "npx prisma migrate deploy --schema ../../packages/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@mergeleague/database": "*",
    "@nestjs/bullmq": "^10.2.1",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/websockets": "^10.4.0",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.34.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.2",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.0",
    "stellar-sdk": "^13.3.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0"
  }
}
