# Copy to apps/api/.env and apps/web/.env.local

DATABASE_URL="postgresql://mergeleague:mergeleague@localhost:5432/mergeleague?schema=public"
REDIS_URL="redis://localhost:6379"
# Set to "true" to always enqueue GitHub sync to BullMQ; "false" forces inline sync.
# If unset, queue is used when REDIS_URL is set.
SYNC_QUEUE=
# Lookback window for GitHub search (days).
GITHUB_SYNC_LOOKBACK_DAYS=30
API_PORT=4000
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"
JWT_SECRET="change-me-in-production-use-long-random-string"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:4000/auth/github/callback"
# PAT for POST /contributions/sync (GraphQL). Fine-grained or classic with repo read scope.
GITHUB_TOKEN=""
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY=""
GITHUB_WEBHOOK_SECRET=""
STELLAR_NETWORK="TESTNET"
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"
STELLAR_POOL_SECRET_KEY=""
STELLAR_POOL_PUBLIC_KEY=""
STELLAR_SECRET_ENCRYPTION_KEY=""
STELLAR_AUTO_FUND_TESTNET_WALLETS="true"
